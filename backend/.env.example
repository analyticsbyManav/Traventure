# Copy this file to .env and fill in your real keys. Never commit .env itself.

PORT=5000

# Anthropic API key for itinerary generation (get one at console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# We use the free OpenStreetMap Overpass API for place data by default,
# so no key is needed there. If you later switch to Google Places API,
# add GOOGLE_PLACES_API_KEY here.

# URL of the Python ML microservice (trip cost prediction)
ML_SERVICE_URL=http://localhost:8001
